{
  "id": "journey-ledger",
  "title": "Journey Ledger",
  "description": "Panorama-style 'day of travel' tracker for D&D 5e. Real-time multi-user sync via socketlib. French UI, 8-phase day, milestone-based trip progress, camp + watch schedule.",
  "version": "1.1.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13.351",
    "maximum": "13"
  },
  "relationships": {
    "systems": [
      {
        "id": "dnd5e",
        "type": "system",
        "compatibility": { "minimum": "5.3.0", "verified": "5.3.2" }
      }
    ],
    "requires": [
      {
        "id": "socketlib",
        "type": "module",
        "compatibility": { "minimum": "1.0.13" }
      }
    ]
  },
  "esmodules": ["scripts/main.js"],
  "styles": ["styles/journey-ledger.css"],
  "socket": true,
  "languages": [{ "lang": "en", "name": "English", "path": "lang/en.json" }],
  "authors": [{ "name": "FrontBrandon14" }],
  "url": "https://github.com/FrontBrandon14/journey-ledger",
